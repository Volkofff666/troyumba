# HTTPS on non-standard port 9443
# TLS cert is issued via HTTP-01 challenge (port 80)
{
    https_port 9443
}

troyumba.ru {
    encode gzip

    log {
        output stdout
        format console
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    # API -> Node.js backend
    @api path /api/*
    handle @api {
        reverse_proxy backend:3000 {
            header_up X-Forwarded-For {remote_host}
            header_up X-Real-IP {remote_host}
        }
    }

    # Static frontend files
    handle {
        root * /srv/frontend
        try_files {path} {path}.html /index.html
        file_server
    }
}

# www -> non-www redirect
www.troyumba.ru {
    redir https://troyumba.ru{uri} permanent
}
