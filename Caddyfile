# HTTP-only: TLS is terminated by Cloudflare proxy
# Cloudflare (443 HTTPS) → VPS port 80 (HTTP) → Caddy
{
    auto_https off
}

http://troyumba.ru {
    encode gzip

    log {
        output stdout
        format console
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    # API -> Node.js backend
    @api path /api/*
    handle @api {
        reverse_proxy backend:3000 {
            # Real visitor IP comes from Cloudflare header
            header_up X-Forwarded-For {http.request.header.CF-Connecting-IP}
            header_up X-Real-IP {http.request.header.CF-Connecting-IP}
        }
    }

    # Static frontend files
    handle {
        root * /srv/frontend
        try_files {path} {path}.html /index.html
        file_server
    }
}

# www -> non-www redirect
http://www.troyumba.ru {
    redir http://troyumba.ru{uri} permanent
}
