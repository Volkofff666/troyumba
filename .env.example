# ==========================================
# Troymba — Environment Variables
# Скопируйте в .env и заполните реальными значениями:
#   cp .env.example .env
# ==========================================

# FreeKassa: ID магазина
# Найти в: https://admin.freekassa.ru → Мои магазины
FK_SHOP_ID=12345

# FreeKassa: API ключ
# Найти в: https://admin.freekassa.ru → Настройки → API ключи
FK_API_KEY=your_api_key_here

# FreeKassa: Секретное слово 2 (для верификации webhook)
# Найти в: https://admin.freekassa.ru → Настройки → Технические настройки
FK_SECRET_WORD_2=your_secret_word_2_here

# Публичный URL сайта (без слеша в конце)
SITE_URL=https://troyumba.ru

# Порт бэкенда (менять не нужно при использовании Docker)
PORT=3000

# FreeKassa: ID платёжных систем для автоматических выплат
# Найти в: https://admin.freekassa.ru → Выплаты → Доступные методы
FK_PAYOUT_CARD_PS_ID=4
FK_PAYOUT_SBP_PS_ID=44
